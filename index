<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="darkreader-lock">
    <meta name="color-scheme" content="light">
    <title>Aesthetic Calendar Widget</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@600;700;800&family=Mali:wght@500;600&display=swap" rel="stylesheet">
    <style>
        :root, html, body {
            forced-color-adjust: none !important;
            color-adjust: exact !important;
        }

        :root {
            /* Sfondi base della pagina Notion */
            --page-bg: transparent; 
            --text-color: #4A3A35;
            
            /* Tema Fragola (Predefinito - Ispirato all'immagine) */
            --accent-main: #C62828;      /* Rosso dei bordi spessi */
            --cell-bg: #FFF0F5;          /* Rosa chiarissimo sfondo celle */
            --badge-bg: #FF8A80;         /* Rosa/Rosso quadratino data */
            --badge-text: #FFFFFF;       /* Testo della data */
            --header-bg: #FFCDD2;        /* Sfondo dei giorni della settimana */
            --btn-bg: #FFF;
        }

        /* --- SFONDI NOTION --- */
        [data-theme="light"] { --page-bg: #FFFFFF; --text-color: #4A3A35; --btn-bg: #FFFFFF; }
        [data-theme="beige"] { --page-bg: #FFFBE6; --text-color: #5A504B; --btn-bg: #FFFBE6; }
        [data-theme="dark"] { --page-bg: #191919; --text-color: #F0F0F0; --btn-bg: #2C2C2C; }
        [data-theme="transparent"] { --page-bg: transparent; }

        /* --- PALETTE COLORI (Estetica Aesthetic) --- */
        [data-color="strawberry"] {
            --accent-main: #C62828; --cell-bg: #FFF0F5; --badge-bg: #FF8A80; --header-bg: #FFCDD2;
        }
        [data-color="matcha"] {
            --accent-main: #2E7D32; --cell-bg: #F1F8E9; --badge-bg: #81C784; --header-bg: #C8E6C9;
        }
        [data-color="blueberry"] {
            --accent-main: #1565C0; --cell-bg: #E3F2FD; --badge-bg: #64B5F6; --header-bg: #BBDEFB;
        }
        [data-color="grape"] {
            --accent-main: #6A1B9A; --cell-bg: #F3E5F5; --badge-bg: #BA68C8; --header-bg: #E1BEE7;
        }
        [data-color="choco"] {
            --accent-main: #4E342E; --cell-bg: #EFEBE9; --badge-bg: #A1887F; --header-bg: #D7CCC8;
        }

        /* Adattamento Dark Mode per la griglia */
        [data-theme="dark"] {
            --cell-bg: #2A2A2A; 
            --header-bg: #3A3A3A;
            --accent-main: #111;
        }
        [data-theme="dark"][data-color="strawberry"] { --accent-main: #5C1313; --badge-bg: #9C3838; }
        [data-theme="dark"][data-color="matcha"] { --accent-main: #143A16; --badge-bg: #3A733E; }
        [data-theme="dark"][data-color="blueberry"] { --accent-main: #0A3261; --badge-bg: #28639C; }
        [data-theme="dark"][data-color="grape"] { --accent-main: #330B4D; --badge-bg: #672F80; }

        body, html {
            margin: 0; padding: clamp(5px, 2vw, 15px); 
            background-color: var(--page-bg);
            font-family: 'Nunito', sans-serif; 
            color: var(--text-color);
            display: flex; flex-direction: column; align-items: center; 
            transition: background-color 0.3s ease;
        }

        /* --- CONTROLLI SUPERIORI --- */
        .controls-container {
            display: flex; gap: 15px; margin-bottom: 20px;
            padding: 8px 20px; background-color: var(--btn-bg); 
            border-radius: 20px; align-items: center; flex-wrap: wrap; 
            justify-content: center; box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            border: 2px solid var(--accent-main);
        }

        .picker-group { display: flex; gap: 8px; align-items: center; }
        .picker-separator { width: 2px; height: 20px; background-color: var(--accent-main); opacity: 0.3; }

        .color-dot {
            width: 18px; height: 18px; border-radius: 50%; cursor: pointer;
            border: 2px solid var(--accent-main); transition: transform 0.2s;
        }
        .color-dot:hover { transform: scale(1.2); }

        .action-btn {
            background-color: var(--badge-bg); color: var(--badge-text); 
            border: 2px solid var(--accent-main); border-radius: 12px; 
            padding: 4px 12px; font-family: 'Nunito', sans-serif; font-weight: 700; 
            cursor: pointer; transition: all 0.2s ease;
        }
        .action-btn:hover { filter: brightness(1.1); transform: translateY(-2px); }
        .action-btn.outline { background-color: var(--btn-bg); color: var(--text-color); }

        /* --- CALENDARIO AESTHETIC --- */
        .calendar-wrapper {
            width: 100%; max-width: 900px;
            display: flex; flex-direction: column; gap: 10px;
        }

        /* Intestazione Mese */
        .month-header {
            display: flex; justify-content: space-between; align-items: center;
            background-color: var(--header-bg); padding: 10px 20px;
            border-radius: 16px; border: 3px solid var(--accent-main);
        }
        .month-header h2 { margin: 0; font-size: 24px; color: var(--accent-main); text-transform: uppercase; font-weight: 800; }
        .nav-btn {
            background: var(--btn-bg); border: 2px solid var(--accent-main);
            color: var(--accent-main); border-radius: 8px; cursor: pointer;
            padding: 4px 12px; font-weight: bold; font-family: 'Nunito';
        }

        /* La Griglia spessa e arrotondata */
        .calendar-frame {
            background-color: var(--accent-main); /* Il bordo spesso esterno e interno */
            padding: 6px; 
            border-radius: 16px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

        .days-row {
            display: grid; grid-template-columns: repeat(7, 1fr);
            gap: 4px; margin-bottom: 4px;
        }
        .day-name {
            background-color: var(--header-bg); color: var(--accent-main);
            text-align: center; font-weight: 800; font-size: 14px;
            padding: 8px 0; border-radius: 8px; text-transform: uppercase;
        }

        .calendar-grid {
            display: grid; grid-template-columns: repeat(7, 1fr);
            gap: 4px; /* Crea le linee della griglia spesse */
        }

        /* Le Singole Celle */
        .cell {
            background-color: var(--cell-bg);
            border-radius: 8px;
            display: flex; flex-direction: column;
            transition: background-color 0.2s;
            position: relative;
        }

        .month-view .cell { min-height: 90px; }
        .week-view .cell { min-height: 350px; } /* Più altezza per la settimana */

        .cell.empty { background-color: rgba(255,255,255,0.4); }
        [data-theme="dark"] .cell.empty { background-color: rgba(0,0,0,0.2); }

        /* Quadratino della data in alto a sinistra */
        .date-badge {
            background-color: var(--badge-bg); color: var(--badge-text);
            border-radius: 6px; padding: 2px 8px; margin: 6px;
            align-self: flex-start; font-weight: 800; font-size: 14px;
            border: 2px solid var(--accent-main);
        }

        /* Area per inserire gli eventi */
        .event-input {
            flex-grow: 1; margin: 0 6px 6px 6px; outline: none;
            font-family: 'Mali', cursive; /* Font in stile scrittura a mano */
            font-size: 14px; color: var(--text-color);
            overflow-y: auto; white-space: pre-wrap; word-wrap: break-word;
            padding: 4px; border-radius: 4px;
        }
        .event-input:focus { background-color: rgba(255,255,255,0.3); }

        /* Scrollbar carina per le celle */
        .event-input::-webkit-scrollbar { width: 6px; }
        .event-input::-webkit-scrollbar-track { background: transparent; }
        .event-input::-webkit-scrollbar-thumb { background: var(--badge-bg); border-radius: 10px; }

    </style>
</head>
<body data-theme="transparent" data-color="strawberry">

    <div class="controls-container">
        <div class="picker-group">
            <div class="color-dot" style="background-color: #E0E0E0;" data-theme-target="transparent" title="Sfondo Notion (Trasparente)"></div>
            <div class="color-dot" style="background-color: #FFFFFF;" data-theme-target="light" title="Chiaro"></div>
            <div class="color-dot" style="background-color: #FFFBE6;" data-theme-target="beige" title="Beige Notion"></div>
            <div class="color-dot" style="background-color: #191919; border-color: #555;" data-theme-target="dark" title="Scuro"></div>
        </div>
        <div class="picker-separator"></div>
        
        <div class="picker-group">
            <div class="color-dot" style="background-color: #C62828;" data-color-target="strawberry" title="Fragola"></div>
            <div class="color-dot" style="background-color: #2E7D32;" data-color-target="matcha" title="Matcha"></div>
            <div class="color-dot" style="background-color: #1565C0;" data-color-target="blueberry" title="Mirtillo"></div>
            <div class="color-dot" style="background-color: #6A1B9A;" data-color-target="grape" title="Uva"></div>
            <div class="color-dot" style="background-color: #4E342E;" data-color-target="choco" title="Cioccolato"></div>
        </div>
        <div class="picker-separator"></div>
        
        <div class="picker-group">
            <button class="action-btn outline" id="view-toggle-btn" onclick="toggleView()">Vista: Mese</button>
            <button class="action-btn" onclick="goToToday()">Oggi</button>
        </div>
    </div>

    <div class="calendar-wrapper">
        <div class="month-header">
            <button class="nav-btn" onclick="navigate(-1)">◀ Precedente</button>
            <h2 id="calendar-title">Mese Anno</h2>
            <button class="nav-btn" onclick="navigate(1)">Successivo ▶</button>
        </div>

        <div class="calendar-frame">
            <div class="days-row">
                <div class="day-name">Lun</div><div class="day-name">Mar</div>
                <div class="day-name">Mer</div><div class="day-name">Gio</div>
                <div class="day-name">Ven</div><div class="day-name">Sab</div>
                <div class="day-name">Dom</div>
            </div>
            <div class="calendar-grid month-view" id="calendar-grid">
                </div>
        </div>
    </div>

    <script>
        // --- SAFE STORAGE ---
        const safeStorage = {
            get: function(key) { try { return localStorage.getItem(key); } catch(e) { return null; } },
            set: function(key, val) { try { localStorage.setItem(key, val); } catch(e) { console.warn("Memoria bloccata."); } }
        };

        // --- GESTIONE TEMI E COLORI ---
        function setTheme(theme) {
            document.body.setAttribute('data-theme', theme);
            safeStorage.set('cal-theme', theme);
        }
        function setColor(color) {
            document.body.setAttribute('data-color', color);
            safeStorage.set('cal-color', color);
        }

        setTheme(safeStorage.get('cal-theme') || 'transparent');
        setColor(safeStorage.get('cal-color') || 'strawberry');

        document.querySelectorAll('[data-theme-target]').forEach(dot => {
            dot.addEventListener('click', () => setTheme(dot.getAttribute('data-theme-target')));
        });
        document.querySelectorAll('[data-color-target]').forEach(dot => {
            dot.addEventListener('click', () => setColor(dot.getAttribute('data-color-target')));
        });

        // --- LOGICA CALENDARIO ---
        let currentView = safeStorage.get('cal-view') || 'month'; // 'month' o 'week'
        let baseDate = new Date(); // Data di riferimento attuale

        const grid = document.getElementById('calendar-grid');
        const title = document.getElementById('calendar-title');
        const viewToggleBtn = document.getElementById('view-toggle-btn');

        const mesi = ["Gennaio", "Febbraio", "Marzo", "Aprile", "Maggio", "Giugno", "Luglio", "Agosto", "Settembre", "Ottobre", "Novembre", "Dicembre"];

        function toggleView() {
            currentView = currentView === 'month' ? 'week' : 'month';
            safeStorage.set('cal-view', currentView);
            renderCalendar();
        }

        function goToToday() {
            baseDate = new Date();
            renderCalendar();
        }

        function navigate(direction) {
            if (currentView === 'month') {
                baseDate.setMonth(baseDate.getMonth() + direction);
            } else {
                baseDate.setDate(baseDate.getDate() + (direction * 7));
            }
            renderCalendar();
        }

        // Calcola il lunedì della settimana in cui si trova la baseDate
        function getMonday(d) {
            let date = new Date(d);
            let day = date.getDay();
            let diff = date.getDate() - day + (day === 0 ? -6 : 1);
            return new Date(date.setDate(diff));
        }

        function formatDateKey(year, month, day) {
            return `${year}-${String(month+1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
        }

        function createCell(year, month, day, isEmpty) {
            const cell = document.createElement('div');
            cell.className = `cell ${isEmpty ? 'empty' : ''}`;
            
            if (!isEmpty) {
                const dateKey = formatDateKey(year, month, day);
                
                const badge = document.createElement('div');
                badge.className = 'date-badge';
                badge.innerText = day;
                
                const input = document.createElement('div');
                input.className = 'event-input';
                input.contentEditable = "true";
                input.setAttribute('spellcheck', 'false');
                
                // Carica i dati salvati
                input.innerHTML = safeStorage.get('calevent-' + dateKey) || '';
                
                // Salva automaticamente mentre scrivi
                input.addEventListener('input', () => {
                    safeStorage.set('calevent-' + dateKey, input.innerHTML);
                });

                cell.appendChild(badge);
                cell.appendChild(input);
            }
            return cell;
        }

        function renderCalendar() {
            grid.innerHTML = '';
            
            const year = baseDate.getFullYear();
            const month = baseDate.getMonth();

            if (currentView === 'month') {
                viewToggleBtn.innerText = "Vista: Mese";
                grid.className = "calendar-grid month-view";
                title.innerText = `${mesi[month]} ${year}`;

                const firstDay = new Date(year, month, 1).getDay();
                const daysInMonth = new Date(year, month + 1, 0).getDate();
                
                // Aggiusta in modo che il lunedì sia 0, domenica 6
                const startPad = firstDay === 0 ? 6 : firstDay - 1; 

                // Celle vuote inizio mese
                for (let i = 0; i < startPad; i++) {
                    grid.appendChild(createCell(year, month, 0, true));
                }

                // Celle con i giorni
                for (let day = 1; day <= daysInMonth; day++) {
                    grid.appendChild(createCell(year, month, day, false));
                }

                // Celle vuote fine mese
                const totalCells = startPad + daysInMonth;
                const endPad = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
                for (let i = 0; i < endPad; i++) {
                    grid.appendChild(createCell(year, month, 0, true));
                }

            } else {
                // VISUALIZZAZIONE SETTIMANALE
                viewToggleBtn.innerText = "Vista: Settimana";
                grid.className = "calendar-grid week-view";
                
                const monday = getMonday(baseDate);
                const sunday = new Date(monday);
                sunday.setDate(sunday.getDate() + 6);
                
                // Mostra il periodo nel titolo (es. "4 - 10 Marzo 2026")
                if(monday.getMonth() === sunday.getMonth()) {
                    title.innerText = `${monday.getDate()} - ${sunday.getDate()} ${mesi[monday.getMonth()]} ${monday.getFullYear()}`;
                } else {
                    title.innerText = `${monday.getDate()} ${mesi[monday.getMonth()].substring(0,3)} - ${sunday.getDate()} ${mesi[sunday.getMonth()].substring(0,3)} ${sunday.getFullYear()}`;
                }

                for (let i = 0; i < 7; i++) {
                    let currentDay = new Date(monday);
                    currentDay.setDate(currentDay.getDate() + i);
                    grid.appendChild(createCell(currentDay.getFullYear(), currentDay.getMonth(), currentDay.getDate(), false));
                }
            }
        }

        // Avvio
        renderCalendar();

    </script>
</body>
</html>
